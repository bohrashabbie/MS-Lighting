# Copy to .env and adjust before `docker compose build`.
# These are PUBLIC values baked into the static build.

# CMS API base (FastAPI). Production:
NEXT_PUBLIC_CMS_URL=http://13.60.4.75:8002

# S3 bucket public base URL (product/category images)
NEXT_PUBLIC_S3_BASE_URL=https://alburhan-asset.s3.eu-north-1.amazonaws.com

# Canonical site URL — used for sitemap, robots, canonical tags, JSON-LD.
# MUST be the real domain in production (not localhost).
NEXT_PUBLIC_SITE_URL=https://www.mslighting.com

# Base URL for site media (video/banners/markets/renders/scenes).
# All media lives in S3 under the "site/" prefix — nothing is served from
# the app's /public folder any more (only logo/favicons remain there).
# Swap for a CloudFront distribution URL later if one is created:
#   NEXT_PUBLIC_ASSET_BASE_URL=https://dXXXXXXXXXXXX.cloudfront.net/site
NEXT_PUBLIC_ASSET_BASE_URL=https://alburhan-asset.s3.eu-north-1.amazonaws.com/site

# Nginx TLS domain (docker-compose.prod.yml)
DOMAIN=example.com
